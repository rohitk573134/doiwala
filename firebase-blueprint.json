{
  "entities": {
    "MenuItem": {
      "title": "MenuItem",
      "description": "A food or drink item on the menu",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the item"
        },
        "category": {
          "type": "string",
          "description": "Category of the item (e.g., Chaat, Snacks, Sweets, Drinks)"
        },
        "price": {
          "type": "string",
          "description": "Price of the item as a string (e.g., '₹210')"
        },
        "desc": {
          "type": "string",
          "description": "Description of the item"
        },
        "tag": {
          "type": "string",
          "description": "Optional tag (e.g., 'Best Seller', 'Popular')"
        },
        "image": {
          "type": "string",
          "description": "URL of the item's image"
        },
        "isSignature": {
          "type": "boolean",
          "description": "Whether this item is a signature item"
        }
      },
      "required": ["name", "category", "price", "desc", "image"]
    }
  },
  "firestore": {
    "/menuItems/{itemId}": {
      "schema": {
        "$ref": "#/entities/MenuItem"
      },
      "description": "Collection of all menu items"
    }
  }
}
